{
  "platformOptions": {
    "Coverlet": {
      "include": "[MyApp]*,[MyApp.*]*",
      "exclude": "[*.Tests]*,[*.Tests.*]*",
      "excludeByAttribute": "ExcludeFromCodeCoverage,GeneratedCode,CompilerGenerated,TestSDKAutoGeneratedCode",
      "excludeAssembliesWithoutSources": "MissingAll",
      "doesNotReturnAttribute": "DoesNotReturn",
      "skipAutoProps": true,
      "format": "cobertura"
    }
  }
}
